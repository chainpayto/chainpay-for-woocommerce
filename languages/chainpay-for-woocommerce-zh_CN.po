msgid "ChainPay for WooCommerce"
msgstr "ChainPay for WooCommerce"

msgid "WooCommerce is required for this plugin to work. Please install and activate WooCommerce first."
msgstr "本插件依赖 WooCommerce，请先安装并启用 WooCommerce。"

msgid "Settings"
msgstr "设置"

msgid "ChainPay (USDT/USDC)"
msgstr "ChainPay（USDT/USDC）"

msgid "Accept USDT / USDC on TRON, BSC and Polygon via ChainPay. Customers are redirected to a hosted checkout page."
msgstr "通过 ChainPay 在 TRON、BSC、Polygon 上收 USDT / USDC。顾客将被跳转至托管收银台完成支付。"

msgid "Enable/Disable"
msgstr "启用 / 停用"

msgid "Enable ChainPay crypto payments"
msgstr "启用 ChainPay 加密货币支付"

msgid "Title"
msgstr "标题"

msgid "This controls the title shown to customers at checkout."
msgstr "顾客在结账页看到的支付方式名称。"

msgid "Crypto (USDT / USDC)"
msgstr "加密货币（USDT / USDC）"

msgid "Description"
msgstr "描述"

msgid "Shown under the payment method at checkout."
msgstr "在结账页上的支付方式下方显示的简介。"

msgid "Pay with USDT or USDC — low fees, instant confirmation."
msgstr "使用 USDT 或 USDC 付款，手续费低，确认即时。"

msgid "ChainPay API credentials"
msgstr "ChainPay API 凭据"

msgid "Generate your API key in the <a href=\"%s\" target=\"_blank\">ChainPay merchant dashboard</a> → API Keys."
msgstr "请到 <a href=\"%s\" target=\"_blank\">ChainPay 商户后台</a> → API 密钥页生成密钥。"

msgid "API Base URL"
msgstr "API 基础 URL"

msgid "Usually you do NOT need to change this."
msgstr "通常无需修改。"

msgid "API Key"
msgstr "API Key"

msgid "API Secret"
msgstr "API Secret"

msgid "Webhook"
msgstr "Webhook"

msgid "In your ChainPay dashboard → Settings, set the callback URL to:<br><code>%1$s</code><br>Then copy the <strong>Webhook Secret</strong> shown there into the field below. Manage at <a href=\"%2$s\" target=\"_blank\">ChainPay settings</a>."
msgstr "在 ChainPay 商户后台 → 设置，把回调 URL 设为：<br><code>%1$s</code><br>然后把页面上显示的 <strong>Webhook Secret</strong> 复制到下方。入口：<a href=\"%2$s\" target=\"_blank\">ChainPay 设置</a>。"

msgid "Webhook Secret"
msgstr "Webhook Secret"

msgid "Used to verify incoming webhooks (HMAC-SHA256)."
msgstr "用于校验收到的回调（HMAC-SHA256）。"

msgid "Payment preferences"
msgstr "收款偏好"

msgid "Default chain"
msgstr "默认链"

msgid "lowest fees"
msgstr "手续费最低"

msgid "The chain your ChainPay order defaults to. Customers still see the final address on the checkout page."
msgstr "ChainPay 订单默认使用的链。顾客在收银台页面仍能看到最终的收款地址。"

msgid "Default token"
msgstr "默认代币"

msgid "Debug log"
msgstr "调试日志"

msgid "Enable debug logging (WooCommerce → Status → Logs → chainpay-*)"
msgstr "启用调试日志（WooCommerce → 状态 → 日志 → chainpay-*）"

msgid "Safe to enable temporarily during setup. Do not leave on in production.."
msgstr "配置阶段可暂时开启，生产环境请关闭。"

msgid "ChainPay API key / secret is not configured."
msgstr "未配置 ChainPay API Key / Secret。"

msgid "Invalid JSON response from ChainPay."
msgstr "ChainPay 返回内容不是合法 JSON。"

msgid "Unknown API error"
msgstr "未知 API 错误"

msgid "HTTP %d"
msgstr "HTTP %d"

msgid "Crypto payment error: %s"
msgstr "加密货币支付失败：%s"

msgid "Crypto payment error: missing checkout URL."
msgstr "加密货币支付失败：未返回收银台 URL。"

msgid "ChainPay order created, awaiting on-chain payment."
msgstr "已创建 ChainPay 订单，等待链上付款。"

msgid "ChainPay payment received: %1$s %2$s on %3$s (tx: %4$s)."
msgstr "ChainPay 收到付款：%3$s %1$s %2$s（交易：%4$s）。"

msgid "ChainPay order expired without payment."
msgstr "ChainPay 订单已过期，未付款。"

msgid "ChainPay reported payment failure."
msgstr "ChainPay 报告付款失败。"
